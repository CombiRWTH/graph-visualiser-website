{
	"name": "graph-visualiser",
	"version": "0.1.0",
	"private": true,
	"dependencies": {
		"@antv/graphin": "^2.7.27",
		"@antv/graphin-components": "^2.4.1",
		"@antv/graphin-icons": "^1.0.0",
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@testing-library/jest-dom": "^5.14.1",
		"@testing-library/react": "^13.0.0",
		"@vitejs/plugin-react": "^4.2.1",
		"chart.js": "^4.4.3",
		"chartjs-plugin-datalabels": "^2.2.0",
		"christofides": "link:./rust/christofides/pkg",
		"culori": "^4.0.2",
		"daisyui": "^4.12.10",
		"dijkstra": "link:./rust/dijkstra/pkg",
		"dinic": "link:./rust/dinic/pkg",
		"edmonds_karp": "link:./rust/edmonds_karp/pkg",
		"edmonds_matching": "link:./rust/edmonds_matching/pkg",
		"ford_fulkerson": "link:./rust/ford_fulkerson/pkg",
		"framer-motion": "^11.2.13",
		"immer": "^10.0.2",
		"intro.js": "^7.2.0",
		"kruskal": "link:./rust/kruskal/pkg",
		"lodash": "^4.17.21",
		"lodash.debounce": "^4.0.8",
		"lucide-react": "^0.376.0",
		"mbf": "link:./rust/mbf/pkg",
		"prim": "link:./rust/prim/pkg",
		"react": "^18.2.0",
		"react-animated-router": "^1.2.4",
		"react-bootstrap": "^2.10.2",
		"react-chartjs-2": "^5.2.0",
		"react-color": "^2.19.3",
		"react-dom": "^18.3.1",
		"react-hook-form": "^7.51.4",
		"react-joyride": "^2.9.3",
		"react-latex-next": "^2.2.0",
		"react-router-dom": "^6.4.3",
		"react-transition-group": "^4.4.5",
		"react-use": "^17.5.0",
		"tailwind-merge": "^2.3.0",
		"type-fest": "^4.38.0",
		"vite": "^6.2.0",
		"zustand": "^4.3.2"
	},
	"devDependencies": {
		"@types/culori": "^4",
		"@types/lodash": "^4",
		"@types/lodash.debounce": "^4",
		"@types/node": "^22.13.10",
		"@types/react": "^18.0.0",
		"@types/react-color": "^3.0.7",
		"@types/react-dom": "^18.0.9",
		"@types/react-router-dom": "^5.3.3",
		"@typescript-eslint/eslint-plugin": "^5.0.0",
		"autoprefixer": "^10.4.21",
		"eslint": "^8.0.1",
		"eslint-config-prettier": "^8.5.0",
		"eslint-config-standard-with-typescript": "^22.0.0",
		"eslint-plugin-import": "^2.25.2",
		"eslint-plugin-n": "^15.0.0",
		"eslint-plugin-prettier": "^4.2.1",
		"eslint-plugin-promise": "^6.0.0",
		"eslint-plugin-react": "^7.31.7",
		"eslint-plugin-tailwindcss": "^3.15.1",
		"eslint-plugin-unused-imports": "^3.1.0",
		"husky": "^8.0.1",
		"lint-staged": "^13.0.3",
		"postcss": "^8.5.3",
		"prettier": "^3.2.5",
		"prettier-plugin-rust": "^0.1.9",
		"tailwindcss": "^3.4.3",
		"tsc-files": "^1.1.3",
		"typescript": "5.1.6"
	},
	"scripts": {
		"start": "vite",
		"build": "vite build",
		"build:algo": "node rust/build.js",
		"test:algo": "node rust/build.js --test",
		"lint": "eslint --fix",
		"format": "prettier --write './**/*.{js,jsx,ts,tsx,css,md,json}' --config ./.prettierrc",
		"format:algo": "cargo +nightly fmt --all",
		"postinstall": "husky install"
	},
	"lint-staged": {
		"!(rust/**/pkg/*)*.{ts,tsx}": [
			"eslint --color --max-warnings 0 --no-ignore"
		],
		"!(rust/**/pkg/*)**/*.{ts,tsx}": "tsc-files --noEmit",
		"!(rust/**/pkg/*)*.{js,jsx,ts,tsx,json,md}": [
			"prettier --write"
		]
	},
	"eslintConfig": {
		"env": {
			"browser": true,
			"es2021": true
		},
		"extends": [
			"standard-with-typescript",
			"plugin:prettier/recommended"
		],
		"overrides": [],
		"parserOptions": {
			"project": [
				"./tsconfig.json"
			],
			"ecmaVersion": "latest",
			"sourceType": "module"
		},
		"plugins": [
			"react"
		],
		"rules": {
			"@typescript-eslint/no-non-null-assertion": "off",
			"@typescript-eslint/strict-boolean-expressions": "off",
			"@typescript-eslint/explicit-function-return-type": "off"
		}
	},
	"browserslist": {
		"production": [
			">0.2%",
			"not dead",
			"not op_mini all"
		],
		"development": [
			"last 1 chrome version",
			"last 1 firefox version",
			"last 1 safari version"
		]
	},
	"packageManager": "yarn@4.5.0",
	"homepage": "https://combirwth.github.io/graph-visualiser-website"
}
